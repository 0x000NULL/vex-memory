# Vex Memory Configuration
# Copy to .env and customize: cp .env.example .env

# Database
POSTGRES_USER=vex
POSTGRES_PASSWORD=vex_memory_dev
POSTGRES_DB=vex_memory
DATABASE_URL=postgresql://vex:vex_memory_dev@db:5432/vex_memory

# Ollama (embeddings)
# If running Ollama on the host, use host.docker.internal from inside Docker
OLLAMA_URL=http://host.docker.internal:11434
EMBED_MODEL=all-minilm
OLLAMA_TIMEOUT=30

# API
VEX_ENV=docker
AUTO_EXTRACT_ENABLED=false
AUTO_EXTRACT_THRESHOLD=0.5

# Optional: Qdrant (vector database alternative)
QDRANT_ENABLED=false
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=vex_memories
